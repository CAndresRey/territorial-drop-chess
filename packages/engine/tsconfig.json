{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "../../",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@tdc/rules": [
        "../rules/src/index.ts"
      ],
      "@tdc/engine": [
        "./src/index.ts"
      ]
    }
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}