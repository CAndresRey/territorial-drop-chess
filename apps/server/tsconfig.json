{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDir": "../.."
  },
  "include": ["src/**/*", "../../packages/**/*.ts"],
  "exclude": ["**/*.test.ts", "**/*.contract.test.ts"]
}
